# Sample environment for the Claude Code A2A agent (LiteLLM endpoint).
# Copy to `.env` and fill in ANTHROPIC_AUTH_TOKEN. Everything else has a default.

# Required: your LiteLLM bearer token.
ANTHROPIC_AUTH_TOKEN=

# Optional overrides (defaults shown):
ANTHROPIC_BASE_URL=https://ete-litellm.ai-models.vpc-int.res.ibm.com
ANTHROPIC_MODEL=sonnet
ANTHROPIC_DEFAULT_HAIKU_MODEL=haiku

WORKSPACE_ROOT=/workspace
MAX_SESSIONS=100
MAX_CONCURRENT=8
TURN_TIMEOUT_S=600
HOST=0.0.0.0
PORT=8000
