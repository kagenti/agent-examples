# Sample environment for the Claude Code A2A agent (LiteLLM endpoint).
# Copy to `.env` and fill in the required values below.

# Required: your LiteLLM bearer token.
ANTHROPIC_AUTH_TOKEN=

# Required: your LiteLLM (Anthropic-compatible) endpoint, e.g.
# https://litellm.example.com. If left empty, Claude Code uses api.anthropic.com.
ANTHROPIC_BASE_URL=

# Optional overrides (defaults shown):
ANTHROPIC_MODEL=sonnet
ANTHROPIC_DEFAULT_HAIKU_MODEL=haiku

WORKSPACE_ROOT=/workspace
MAX_SESSIONS=100
MAX_CONCURRENT=8
TURN_TIMEOUT_S=600
HOST=0.0.0.0
PORT=8000
